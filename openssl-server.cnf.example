[ req ]
default_bits       = 2048
prompt             = no
default_md         = sha256
req_extensions     = req_ext
distinguished_name = dn

[ dn ]
C  = RU
ST = Moscow
L  = Moscow
O  = Debug HTTPS Logger
OU = Integration Debug
CN = debug-server.local

[ req_ext ]
subjectAltName = @alt_names

[ alt_names ]
DNS.1 = debug-server.local
IP.1 = 127.0.0.1
